{
  "_generator": "GENERATED BY AI CODE STACK",

  "alias_routes": [
    "gstack-benchmark"
  ],
  "caveman": {
    "prohibited": [
      "code",
      "command",
      "stack_trace",
      "terminal_output",
      "migration",
      "sql",
      "json",
      "yaml",
      "security_report",
      "test_result",
      "error_message",
      "file_path",
      "diff",
      "config"
    ],
    "scope": "safe_final_user_prose_only"
  },
  "graphify": {
    "legacy_routing": {
      "automatic_when": [
        "large_repository",
        "architecture_analysis",
        "dependency_analysis",
        "impact_analysis",
        "multi_file_refactor",
        "complex_call_chain",
        "cross_module_relationships"
      ],
      "rebuild_index": "only_when_missing_or_stale_for_required_analysis",
      "skip_when": [
        "small_ui_change",
        "copy_change",
        "single_file_local_change",
        "simple_config_change"
      ]
    },
    "role_policy": {
      "decision_flow": [
        "task_classified",
        {
          "repository_intelligence_required": "no -> continue with registry metadata"
        },
        {
          "repository_intelligence_required_yes": [
            {
              "valid_index_exists": "yes -> reuse"
            },
            {
              "valid_index_exists_no": "build only for the required scope"
            }
          ]
        }
      ],
      "index_invalidation_signals": [
        "relevant_source_changed",
        "repository_commit_changed",
        "index_schema_changed",
        "graphify_version_incompatible",
        "checksum_verification_failed"
      ],
      "not_a": [
        "skill_memory",
        "knowledge_registry_replacement",
        "cross_platform_memory"
      ],
      "rebuild_policy": "never_rebuild_every_task",
      "role": "repository_code_intelligence_only",
      "schema_version": 1,
      "skip_when": [
        "simple_question",
        "small_ui_change",
        "text_edit",
        "single_file_local_fix",
        "skill_discovery"
      ],
      "use_when": [
        "large_repository",
        "architecture_analysis",
        "dependency_analysis",
        "impact_analysis",
        "multi_file_refactor",
        "complex_call_chain",
        "cross_module_relationship_analysis"
      ]
    }
  },
  "schema_version": 1,
  "security_flow": {
    "fail_closed": true,
    "flow": [
      "review",
      "risk_classification",
      "cso_if_risky",
      "qa",
      "verification",
      "release_gate",
      "ship"
    ]
  },
  "singletons": {
    "general_reviewer": 1,
    "overlapping_security_specialist": 1,
    "planner": 1
  },
  "task_classes": {
    "large_or_risky": {
      "examples": [
        "repository_wide_architecture_work",
        "multi_module_refactor",
        "installer_or_verifier_infrastructure",
        "auth_payment_secrets_tenant_isolation",
        "multi_platform_adapter_system"
      ],
      "graphify": "when_repository_relationships_are_genuinely_needed",
      "hard_limit_skills": 5,
      "hard_limit_subagents": 3,
      "planner_or_architect": "when_genuinely_needed",
      "preferred_skills": [
        2,
        4
      ],
      "preferred_subagents": [
        1,
        2
      ],
      "qa_or_release_review": "when_needed_for_verification",
      "security_reviewer": "when_a_risky_area_is_touched"
    },
    "medium": {
      "examples": [
        "new_feature",
        "change_affecting_a_few_modules",
        "independent_frontend_or_backend_work",
        "meaningful_test_or_adapter_work"
      ],
      "graphify": "conditional",
      "max_skills": 3,
      "max_subagents": 2,
      "planner": "conditional",
      "preferred_skills": [
        1,
        3
      ],
      "preferred_subagents": 1,
      "reviewer_or_qa": "when_appropriate"
    },
    "question": {
      "architect": false,
      "examples": [
        "explanation",
        "evaluation",
        "information_request"
      ],
      "graphify": false,
      "max_skills": 1,
      "max_subagents": 0,
      "planner": false,
      "repository_change": false
    },
    "small": {
      "examples": [
        "scoped_bug_fix",
        "small_ui_component",
        "local_change_across_a_few_related_files"
      ],
      "graphify": false,
      "max_skills": 2,
      "max_subagents": 1,
      "planner": false,
      "preferred_skills": 1,
      "preferred_subagents": 0,
      "reviewer_or_qa": "only_if_measurable_benefit"
    },
    "tiny": {
      "architect": false,
      "examples": [
        "typo",
        "small_text_change",
        "single_value_or_config_fix",
        "local_single_file_change"
      ],
      "graphify": false,
      "max_skills": 1,
      "max_subagents": 0,
      "planner": false,
      "reviewer": "only_if_high_risk"
    }
  }
}
